// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  // Fly.io runs Debian bookworm-slim (OpenSSL 3.0) in our container.
  // Without an explicit target the generated client only ships the
  // local-OS engine (Mac on dev), causing runtime "Unable to open
  // database file" errors on production because the engine falls
  // back to a SQLite-flavoured binary. The rhel-openssl-3.0.x target
  // is the right one for any modern Linux container with OpenSSL 3.x.
  // See docs/decisions/ADR-009-backend-fly-io.md for the migration
  // history (Vercel → Fly.io).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  // Production: Fly Managed Postgres (DATABASE_URL set via
  // `fly secrets set` on app stockly-lustrous-forest-4364).
  // Local dev: set DATABASE_URL in .env to a local Postgres URL.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Session — managed by @shopify/shopify-app-session-storage-prisma
// Do NOT modify the columns here unless the Shopify package requires it.
// ---------------------------------------------------------------------------
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// ---------------------------------------------------------------------------
// Stockly domain models
// ---------------------------------------------------------------------------

/// One row per installed Shopify store. The id is the shop domain
/// (e.g. "desarrollo-adspubli.myshopify.com").
model Shop {
  id                 String              @id
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  /// Stringified JSON: { primaryColor, accentColor, fontFamily, logoUrl }
  branding           String?
  /// Stringified JSON: { errorMinQty, errorMinValue, emptyState, cta, ... }
  copy               String?

  /// Customer tag that grants wholesale access (default convention).
  wholesaleTag       String              @default("wholesale")

  /// Optional minimum order value (in the shop's currency).
  minOrderValue      Float?

  /// True once the store owner has completed onboarding.
  onboarded          Boolean             @default(false)

  /// Universal wholesale discount on retail price (ADR-006).
  /// 0 = no baseline (default: wholesale customers see retail prices,
  /// only tiers apply). 65 means "wholesale customers see retail × 0.35".
  /// Tiers compose multiplicatively on top of this baseline.
  wholesaleBaselinePct Int                @default(0)

  // ----- First-Purchase Qualifier (ADR-004) -----
  /// How the FPQ is evaluated. 'none' = no gate (default — preserves
  /// pre-FPQ behavior). 'amount' = cart subtotal threshold. 'quantity'
  /// = cart unit count. 'combined' = both, with fpqCombinedLogic.
  fpqMode            String              @default("none")
  /// Minimum cart subtotal (in shop currency) for first-order
  /// qualification when fpqMode is 'amount' or 'combined'.
  fpqAmount          Float?
  /// Minimum cart quantity for first-order qualification when
  /// fpqMode is 'quantity' or 'combined'.
  fpqQuantity        Int?
  /// If fpqMode = 'combined', how amount and quantity combine.
  /// 'and' = both required, 'or' = either suffices.
  fpqCombinedLogic   String              @default("and")
  /// Minimum order quantity AFTER the customer has been qualified.
  /// 1 = no minimum (default — once qualified, customer buys freely).
  postQualificationMOQ Int               @default(1)

  tiers                Tier[]
  wholesaleCustomers   WholesaleCustomer[]
  applications         WholesaleApplication[]
  onboardingResponses  OnboardingResponse[]

  /// Registration Forms for this shop (RF Phase 1 — N-forms, ADR-013).
  /// One row is flagged `isDefault` and serves as the storefront
  /// fallback when no shortcode is supplied. Seeded lazily by
  /// `ensureDefaultRegistrationForm` on first install or storefront fetch.
  registrationForms    RegistrationForm[]
  /// Generic submission table that replaces WholesaleApplication.
  /// Both tables coexist during the soak window (Phase 1A–1F); the
  /// legacy table is dropped in Phase 1G.
  formApplications     Application[]
}

/// Volume pricing tier. `scope` is one of 'product' | 'collection' | 'all'.
/// When `scope = 'all'`, `scopeId` MUST be null. Otherwise `scopeId`
/// holds the Shopify GID (e.g. "gid://shopify/Product/123").
model Tier {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  name        String
  /// ADR-014 (2026-05-28): which admin area owns this rule.
  ///   'wholesale' (default): a flat wholesale discount — single
  ///     discount per rule, no quantity dimension. Managed under
  ///     /app/pricing (Wholesale Pricing). Every existing row
  ///     back-fills to this.
  ///   'volume': a quantity-break rule — N bands sharing a groupId.
  ///     Managed under /app/volume-pricing (Volume Pricing).
  /// kind is organizational only — the Discount Function reads the
  /// same metafield and applies discounts identically regardless of
  /// kind. It exists so the two admin lists can filter their own rules.
  kind        String   @default("wholesale")
  scope       String   // 'product' | 'variant' | 'collection' | 'all'
  /// DEPRECATED 2026-05-27: legacy single-target GID. Kept for one
  /// release cycle for back-compat reads; new code reads scopeIds[]
  /// which can hold many. On every write we mirror scopeIds[0] here
  /// so any old code path that still reads scopeId keeps working.
  scopeId     String?
  /// NEW 2026-05-27: multiple target GIDs for one rule. Per Jonatan's
  /// UX request — Sami/BSS let you pick N products for a single rule
  /// instead of duplicating the rule N times. Empty array when
  /// scope='all'. For scope=product/variant/collection, holds the
  /// list of GIDs the rule applies to.
  scopeIds    String[] @default([])

  minQty      Int
  /// Percent discount, 0-100 (10 means -10%). Used when discountType
  /// is "percentage". Kept for legacy / current data.
  discountPct Float
  /// Type of discount applied at checkout:
  ///   - "percentage" (default): use discountPct, applies as a
  ///     multiplier (1 − discountPct/100). Current behavior.
  ///   - "fixed_amount": use discountAmount, applies as a flat
  ///     subtraction per cart line (in shop currency). Added
  ///     2026-05-27 to match Sami / BSS Essential parity.
  discountType    String  @default("percentage")
  /// Fixed monetary amount off per line, in shop currency. Only
  /// read when discountType = "fixed_amount". null otherwise.
  discountAmount  Float?

  /// How `minQty` is evaluated against the cart (ADR-007):
  ///   - 'per_line' (default): each cart line independently must
  ///     have qty >= minQty for the tier to apply to that line.
  ///     Existing Sprint 2 behavior.
  ///   - 'cart_total': SUM of all line quantities (within the tier's
  ///     scope) must meet minQty. If met, the discount applies to
  ///     every line in scope. Faire-style assortment minimums.
  aggregation String   @default("per_line")

  /// Per-rule customer eligibility (ADR-011 — Sami-parity 2026-05-27).
  ///   'wholesale_tagged' (default): only customers with the shop's
  ///     configured wholesale tag. Preserves pre-2026-05-27 behavior
  ///     (every existing rule maps to this value via the column
  ///     default).
  ///   'logged_in': any authenticated customer (no tag required).
  ///     Useful for invite-only stores where account-creation itself
  ///     is the wholesale gate.
  ///   'all_customers': everyone — including anonymous shoppers.
  ///     Breaks the B2B premise (anyone visiting the storefront sees
  ///     the discount). Surfaced in UI with a warning banner.
  ///   'specific_customers': RESERVED (Sprint 5) — manual list of
  ///     customer GIDs the rule applies to. Function returns
  ///     NO_DISCOUNT for this mode until the list-of-GIDs field
  ///     ships, so it's safe to land the enum value now.
  customerEligibility String @default("wholesale_tagged")

  /// Per-rule market eligibility (2026-05-27, Sami-parity).
  ///   'all_markets' (default): rule applies across every Market the
  ///     shop has configured. Preserves pre-2026-05-27 behavior — no
  ///     existing rows are filtered out at checkout.
  ///   'specific_markets': RESERVED (Sprint 5) — the rule only applies
  ///     when the cart's `localization.market.id` is in `marketIds`.
  ///     UI surfaces this option as disabled until the Markets picker
  ///     and Function input.graphql change ship.
  marketEligibility String   @default("all_markets")
  /// GIDs of Shopify Markets this rule is restricted to when
  /// marketEligibility = 'specific_markets'. Empty array otherwise.
  /// Stored as String[] (Postgres native) mirroring scopeIds.
  marketIds         String[] @default([])

  active      Boolean  @default(true)
  /// Display order in the admin UI.
  position    Int      @default(0)

  // ----- Volume Pricing multi-band (ADR-012, 2026-05-27) -----
  /// Upper-bound quantity for this band (inclusive). null = open-ended
  /// "and above". Only the band with the highest minQty in a group may
  /// be null; the service layer enforces this invariant.
  quantityTo  Int?
  /// Groups bands of the same logical Volume Pricing rule. All bands
  /// of one rule share this id. Nullable for one release cycle while
  /// legacy single-band tiers are back-filled (see
  /// scripts/backfill-tier-groupids.ts).
  groupId     String?
  /// Per-unit final price in shop currency. Used when
  /// discountType = 'fixed_price' — overrides the retail price
  /// entirely (no baseline composition). Null otherwise.
  discountFixedPrice Float?
  /// Optional window during which the band is active. Read by the WASM
  /// Discount Function at run time (no cron). null = no gate.
  startsAt    DateTime?
  endsAt      DateTime?
  /// Phase-1 storage for the storefront "Show table on PDP" toggle.
  /// The theme app block that renders the table ships in Phase 2.
  showTableOnPdp   Boolean  @default(false)
  /// Reserved (Phase 2): template id for the storefront table widget.
  tableTemplateId  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId, active])
  @@index([shopId, scope, scopeId])
  @@index([shopId, groupId])
}

/// Cache of customers approved for wholesale on this shop.
/// `shopifyCustomerId` is stored as String to avoid BigInt edge cases
/// across JS/SQLite/Postgres boundaries.
model WholesaleCustomer {
  id                String   @id @default(cuid())
  shopId            String
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  shopifyCustomerId String
  email             String?

  approvedAt        DateTime @default(now())
  notes             String?

  // ----- FPQ qualification state (ADR-004) -----
  /// When the customer's first qualifying order was paid. null = still
  /// in `approved_pre_fpq` state (must meet FPQ on next checkout). Once
  /// set, the customer is `qualified` (terminal) and can buy freely.
  qualifiedAt              DateTime?
  /// Shopify order GID that triggered qualification (audit trail).
  qualifyingOrderId        String?
  /// The total of the qualifying order (audit trail).
  qualifyingOrderAmount    Float?

  @@unique([shopId, shopifyCustomerId])
  @@index([shopId, email])
}

/// Wholesale account application. A retail visitor (or a logged-in
/// retail customer) submits the form on the storefront; the merchant
/// approves or rejects from the admin queue.
///
/// On approve we:
///   1. Look up or create a Shopify Customer with this email
///   2. Tag them with the shop's wholesaleTag (auto-tagging — ADR-008)
///   3. Create a WholesaleCustomer row (which the App Proxy uses
///      as the eligibility source-of-truth alongside the Shopify tag)
///   4. Move this application's status to 'approved' (audit trail kept)
///
/// On reject we just flip the status — no Shopify side-effect.
model WholesaleApplication {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  /// 'pending' (default) | 'approved' | 'rejected'
  status      String   @default("pending")

  // Applicant identity
  email       String
  firstName   String?
  lastName    String?
  phone       String?

  // Business details
  companyName String
  taxId       String?       // VAT / EIN / CIF
  website     String?
  country     String?
  /// Free-text "tell us about your business" field. Trimmed/length-limited
  /// at the form layer — the admin shows this to inform approval.
  notes       String?

  /// If the applicant was logged in when they submitted, we remember
  /// their Shopify customer id so we can tag them directly on approval
  /// (no need to invite a new account).
  shopifyCustomerId String?

  /// Merchant note added during review.
  reviewNote  String?
  reviewedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId, status, createdAt])
  @@index([shopId, email])
}

// ---------------------------------------------------------------------------
// Registration Form Builder (ADR-013, Phase 1A — 2026-05-28)
// ---------------------------------------------------------------------------

/// Sami-style schema-driven Registration Form. One row per shop
/// (singleton) — seeded lazily by `ensureDefaultRegistrationForm` with
/// a back-compat default that mirrors the legacy hardcoded 8-field form
/// 1:1 so existing storefront POSTs keep validating during the soak.
///
/// Stored as JSON blobs (not normalized tables) because:
///   - Phase 1 only supports a single form per shop (no FK fan-out).
///   - The shape evolves with the builder UI; adding a column for every
///     new field-type knob would mean a schema migration per UX change.
///   - The storefront renderer just deserializes and emits inputs — no
///     SQL joins needed at request time.
model RegistrationForm {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  /// Merchant-facing label shown in the admin list (Phase 1 N-forms).
  /// Defaulted so existing single-row shops backfill safely.
  name        String   @default("Registration form")

  /// Public embed handle. The storefront block passes this as
  /// `?shortcode=` to resolve a specific form; absent → the shop's
  /// `isDefault` active form (dual-serve back-compat). Globally unique.
  shortCode   String   @unique @default(cuid())

  /// Exactly one row per shop is the default; the storefront serves it
  /// when no shortcode is supplied. The back-compat seed marks itself
  /// default so legacy single-row shops keep working.
  isDefault   Boolean  @default(false)

  /// 'active' is served by the storefront block; 'draft' falls back to
  /// the seeded default form so the storefront never breaks.
  status      String   @default("active")

  /// Definition JSON. Shape (TS = RegistrationFormDefinition):
  ///   { steps: [{ id, titleEn, fields: FormField[] }] }
  /// Phase 1: `steps` is always length 1 (multi-step deferred to P2).
  definition  Json

  /// Appearance JSON. Shape (TS = FormAppearance):
  ///   { layout: 'default' | 'boxed', width: number,
  ///     colors: { main, heading, label, description, option,
  ///               paragraph, paragraphBg },
  ///     background: { type: 'color', color: string },
  ///     customCss: string }
  appearance  Json

  /// Settings JSON. Shape (TS = FormSettings):
  ///   { titleEn: string, redirectUrl?: string,
  ///     errorMessages: { required, invalid, invalidEmail, invalidPhone,
  ///       tooLong, tooShort, mismatch, networkError, genericError } }
  settings    Json

  /// Monotonic counter bumped on every save. Used by the storefront
  /// fetch as a cache-busting hint and by the admin preview to detect
  /// stale renders.
  version     Int      @default(1)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId])
}

/// Generic form submission. Replaces `WholesaleApplication`. The full
/// payload lives in `responses` Json (keyed by field key, including
/// snake_case legacy keys for back-compat). `email` is denormalized
/// for fast GDPR webhook lookups and queue filtering.
model Application {
  id                String   @id @default(cuid())
  shopId            String
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  status            String   @default("pending")  // pending | approved | rejected

  /// Full submission as JSON, keyed by the form definition's field keys.
  /// Example (legacy seed default):
  ///   { email, first_name, last_name, phone, company_name, tax_id,
  ///     website, country, notes }
  responses         Json

  /// Always derived from responses.email (lowercased + trimmed) at
  /// write time. Denormalized so GDPR redact / customer-data-request
  /// webhooks don't have to JSON-scan every row.
  email             String

  /// Numeric Shopify customer id, if the applicant was logged in when
  /// they submitted (App Proxy `logged_in_customer_id` query param).
  shopifyCustomerId String?

  reviewNote        String?
  reviewedAt        DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([shopId, status, createdAt])
  @@index([shopId, email])
}

/// Lead-scoring + roadmap signal. Una fila por step del wizard que el
/// merchant completa o salta. Usada para (1) recomendar tier de pricing,
/// (2) priorizar roadmap por agregación, (3) ruteo de outreach Adspubli.
model OnboardingResponse {
  id            String   @id @default(cuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  /// 1 | 2 | 3 — número de step
  step          Int
  /// JSON stringified. Shape depende del step:
  ///   step 1: { journey, businessModel }
  ///   step 2: { presetKey, overrides: { baselinePct?, fpqMode?, ... } }
  ///   step 3: { wantsWhiteGlove: boolean, contactPreference?, message? }
  responsesJson String
  /// True si el merchant clickeó "I'll do this later"
  skipped       Boolean  @default(false)
  completedAt   DateTime @default(now())

  @@index([shopId, step])
}
