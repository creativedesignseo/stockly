// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

// ---------------------------------------------------------------------------
// Session — managed by @shopify/shopify-app-session-storage-prisma
// Do NOT modify the columns here unless the Shopify package requires it.
// ---------------------------------------------------------------------------
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// ---------------------------------------------------------------------------
// Stockly domain models
// ---------------------------------------------------------------------------

/// One row per installed Shopify store. The id is the shop domain
/// (e.g. "desarrollo-adspubli.myshopify.com").
model Shop {
  id                 String              @id
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  /// Stringified JSON: { primaryColor, accentColor, fontFamily, logoUrl }
  branding           String?
  /// Stringified JSON: { errorMinQty, errorMinValue, emptyState, cta, ... }
  copy               String?

  /// Customer tag that grants wholesale access (default convention).
  wholesaleTag       String              @default("wholesale")

  /// Optional minimum order value (in the shop's currency).
  minOrderValue      Float?

  /// True once the store owner has completed onboarding.
  onboarded          Boolean             @default(false)

  /// Universal wholesale discount on retail price (ADR-006).
  /// 0 = no baseline (default: wholesale customers see retail prices,
  /// only tiers apply). 65 means "wholesale customers see retail × 0.35".
  /// Tiers compose multiplicatively on top of this baseline.
  wholesaleBaselinePct Int                @default(0)

  // ----- First-Purchase Qualifier (ADR-004) -----
  /// How the FPQ is evaluated. 'none' = no gate (default — preserves
  /// pre-FPQ behavior). 'amount' = cart subtotal threshold. 'quantity'
  /// = cart unit count. 'combined' = both, with fpqCombinedLogic.
  fpqMode            String              @default("none")
  /// Minimum cart subtotal (in shop currency) for first-order
  /// qualification when fpqMode is 'amount' or 'combined'.
  fpqAmount          Float?
  /// Minimum cart quantity for first-order qualification when
  /// fpqMode is 'quantity' or 'combined'.
  fpqQuantity        Int?
  /// If fpqMode = 'combined', how amount and quantity combine.
  /// 'and' = both required, 'or' = either suffices.
  fpqCombinedLogic   String              @default("and")
  /// Minimum order quantity AFTER the customer has been qualified.
  /// 1 = no minimum (default — once qualified, customer buys freely).
  postQualificationMOQ Int               @default(1)

  tiers              Tier[]
  wholesaleCustomers WholesaleCustomer[]
  applications       WholesaleApplication[]
}

/// Volume pricing tier. `scope` is one of 'product' | 'collection' | 'all'.
/// When `scope = 'all'`, `scopeId` MUST be null. Otherwise `scopeId`
/// holds the Shopify GID (e.g. "gid://shopify/Product/123").
model Tier {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  name        String
  scope       String   // 'product' | 'collection' | 'all'
  scopeId     String?

  minQty      Int
  /// Percent discount, 0-100 (10 means -10%).
  discountPct Float

  /// How `minQty` is evaluated against the cart (ADR-007):
  ///   - 'per_line' (default): each cart line independently must
  ///     have qty >= minQty for the tier to apply to that line.
  ///     Existing Sprint 2 behavior.
  ///   - 'cart_total': SUM of all line quantities (within the tier's
  ///     scope) must meet minQty. If met, the discount applies to
  ///     every line in scope. Faire-style assortment minimums.
  aggregation String   @default("per_line")

  active      Boolean  @default(true)
  /// Display order in the admin UI.
  position    Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId, active])
  @@index([shopId, scope, scopeId])
}

/// Cache of customers approved for wholesale on this shop.
/// `shopifyCustomerId` is stored as String to avoid BigInt edge cases
/// across JS/SQLite/Postgres boundaries.
model WholesaleCustomer {
  id                String   @id @default(cuid())
  shopId            String
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  shopifyCustomerId String
  email             String?

  approvedAt        DateTime @default(now())
  notes             String?

  // ----- FPQ qualification state (ADR-004) -----
  /// When the customer's first qualifying order was paid. null = still
  /// in `approved_pre_fpq` state (must meet FPQ on next checkout). Once
  /// set, the customer is `qualified` (terminal) and can buy freely.
  qualifiedAt              DateTime?
  /// Shopify order GID that triggered qualification (audit trail).
  qualifyingOrderId        String?
  /// The total of the qualifying order (audit trail).
  qualifyingOrderAmount    Float?

  @@unique([shopId, shopifyCustomerId])
  @@index([shopId, email])
}

/// Wholesale account application. A retail visitor (or a logged-in
/// retail customer) submits the form on the storefront; the merchant
/// approves or rejects from the admin queue.
///
/// On approve we:
///   1. Look up or create a Shopify Customer with this email
///   2. Tag them with the shop's wholesaleTag (auto-tagging — ADR-008)
///   3. Create a WholesaleCustomer row (which the App Proxy uses
///      as the eligibility source-of-truth alongside the Shopify tag)
///   4. Move this application's status to 'approved' (audit trail kept)
///
/// On reject we just flip the status — no Shopify side-effect.
model WholesaleApplication {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  /// 'pending' (default) | 'approved' | 'rejected'
  status      String   @default("pending")

  // Applicant identity
  email       String
  firstName   String?
  lastName    String?
  phone       String?

  // Business details
  companyName String
  taxId       String?       // VAT / EIN / CIF
  website     String?
  country     String?
  /// Free-text "tell us about your business" field. Trimmed/length-limited
  /// at the form layer — the admin shows this to inform approval.
  notes       String?

  /// If the applicant was logged in when they submitted, we remember
  /// their Shopify customer id so we can tag them directly on approval
  /// (no need to invite a new account).
  shopifyCustomerId String?

  /// Merchant note added during review.
  reviewNote  String?
  reviewedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId, status, createdAt])
  @@index([shopId, email])
}
