          "value": "{\"wholesaleBaselinePct\":0,\"tiers\":[{\"scope\":\"all\",\"scopeIds\":[],\"groupId\":\"g_test_1\",\"minQty\":1,\"quantityTo\":9,\"discountPct\":5,\"discountType\":\"percentage\",\"aggregation\":\"per_line\",\"customerEligibility\":\"wholesale_tagged\"},{\"scope\":\"all\",\"scopeIds\":[],\"groupId\":\"g_test_1\",\"minQty\":10,\"quantityTo\":49,\"discountPct\":10,\"discountType\":\"percentage\",\"aggregation\":\"per_line\",\"customerEligibility\":\"wholesale_tagged\"},{\"scope\":\"all\",\"scopeIds\":[],\"groupId\":\"g_test_1\",\"minQty\":50,\"quantityTo\":null,\"discountPct\":20,\"discountType\":\"percentage\",\"aggregation\":\"per_line\",\"customerEligibility\":\"wholesale_tagged\"}]}"
