{
  "_comment": "ADR-012 guardrail: a tier with startsAt = 2099-01-01 must NOT apply. Catches a Date.now() regression in the WASM runtime — if Date.now() returned 0 silently, the comparison nowIso > startsAt would be false and the tier would slip through.",
  "payload": {
    "export": "run",
    "target": "purchase.product-discount.run",
    "input": {
      "cart": {
        "lines": [
          {
            "id": "gid://shopify/CartLine/0",
            "quantity": 50,
            "cost": {
              "amountPerQuantity": {
                "amount": "100.00"
              }
            },
            "merchandise": {
              "__typename": "ProductVariant",
              "id": "gid://shopify/ProductVariant/1",
              "product": {
                "id": "gid://shopify/Product/1"
              }
            }
          }
        ],
        "buyerIdentity": {
          "customer": {
            "id": "gid://shopify/Customer/1",
            "hasAnyTag": true
          }
        }
      },
      "discountNode": {
        "metafield": {
          "value": "{\"wholesaleBaselinePct\":0,\"tiers\":[{\"scope\":\"all\",\"scopeIds\":[],\"groupId\":\"g_future_1\",\"minQty\":1,\"quantityTo\":null,\"discountPct\":20,\"discountType\":\"percentage\",\"aggregation\":\"per_line\",\"customerEligibility\":\"wholesale_tagged\",\"startsAt\":\"2099-01-01T00:00:00.000Z\",\"endsAt\":null}]}"
        }
      }
    },
    "output": {
      "discountApplicationStrategy": "ALL",
      "discounts": []
    }
  }
}
