{%- comment -%}
  Stockly — Wholesale Registration Form (Sami-style, schema-driven)

  Thin shell. The actual form is rendered at runtime by
  `registration-form.js` from a JSON definition fetched via App Proxy
  (`GET /apps/stockly/registration-form`).

  Why so little Liquid?
    - The merchant designs the form in the admin (Sami-style builder).
    - The same JSON definition powers the admin preview AND this
      storefront block. Single source of truth.
    - Field labels, types, ordering, validation rules, appearance
      colors, custom CSS, layout (default/boxed), max-width — all live
      in the definition. Theme settings here only carry the fallback
      heading/intro and the already-wholesale notice.

  Failure mode: if the proxy GET fails, the JS renders a minimal hard-
  coded form (email + first/last name + company) so customers can still
  apply. The page never breaks.

  Customer-on-storefront context (Liquid customer.tags) is forwarded
  as data attributes so the JS can:
    - pre-fill email/first/last when known
    - hide the form for already-approved wholesale customers
{%- endcomment -%}

{%- assign already_wholesale = false -%}
{%- if customer and customer.tags contains 'wholesale' -%}
  {%- assign already_wholesale = true -%}
{%- endif -%}

{%- assign customer_email = '' -%}
{%- assign customer_first = '' -%}
{%- assign customer_last  = '' -%}
{%- if customer -%}
  {%- assign customer_email = customer.email -%}
  {%- assign customer_first = customer.first_name -%}
  {%- assign customer_last  = customer.last_name -%}
{%- endif -%}

<stockly-registration
  class="stockly-reg"
  data-action-url="/apps/stockly/apply"
  data-fetch-url="/apps/stockly/registration-form"
  data-already-wholesale="{{ already_wholesale }}"
  data-shop="{{ shop.permanent_domain }}"
  data-customer-email="{{ customer_email | escape }}"
  data-customer-first-name="{{ customer_first | escape }}"
  data-customer-last-name="{{ customer_last | escape }}"
  data-fallback-heading="{{ block.settings.heading | escape }}"
  data-fallback-intro="{{ block.settings.intro | escape }}"
  data-fallback-submit-label="{{ block.settings.submit_label | escape }}"
  data-fallback-success-heading="{{ block.settings.success_heading | escape }}"
  data-fallback-success-body="{{ block.settings.success_body | escape }}"
  data-already-text="{{ block.settings.already_wholesale_text | escape }}"
  {{ block.shopify_attributes }}
>
  {%- comment -%} Mount point — JS replaces the loading skeleton with the rendered form. {%- endcomment -%}
  <div class="stockly-reg__root" data-stockly-root>
    <div class="stockly-reg__skeleton" data-stockly-skeleton aria-hidden="true">
      <div class="stockly-reg__skeleton-line stockly-reg__skeleton-line--lg"></div>
      <div class="stockly-reg__skeleton-line"></div>
      <div class="stockly-reg__skeleton-grid">
        <div class="stockly-reg__skeleton-field"></div>
        <div class="stockly-reg__skeleton-field"></div>
        <div class="stockly-reg__skeleton-field"></div>
        <div class="stockly-reg__skeleton-field"></div>
      </div>
      <div class="stockly-reg__skeleton-button"></div>
    </div>
  </div>

  {%- comment -%}
    Hidden noscript shell — if JS never loads, fall back to a minimal
    static form so a customer can still get in touch. Same action URL.
  {%- endcomment -%}
  <noscript>
    <form class="stockly-reg__form stockly-reg__form--noscript" action="/apps/stockly/apply" method="post">
      <label class="stockly-reg__field">
        <span class="stockly-reg__label">Email</span>
        <input type="email" name="email" required value="{{ customer_email }}">
      </label>
      <label class="stockly-reg__field">
        <span class="stockly-reg__label">First name</span>
        <input type="text" name="first_name" value="{{ customer_first }}">
      </label>
      <label class="stockly-reg__field">
        <span class="stockly-reg__label">Last name</span>
        <input type="text" name="last_name" value="{{ customer_last }}">
      </label>
      <label class="stockly-reg__field">
        <span class="stockly-reg__label">Company name</span>
        <input type="text" name="company_name" required>
      </label>
      <button type="submit" class="stockly-reg__submit">{{ block.settings.submit_label }}</button>
    </form>
  </noscript>
</stockly-registration>

{% schema %}
{
  "name": "Wholesale Registration",
  "target": "section",
  "stylesheet": "registration-form.css",
  "javascript": "registration-form.js",
  "settings": [
    {
      "type": "paragraph",
      "content": "Form fields, colors, layout and validation messages are managed in the Stockly admin under Registration Form. The settings below are fallback copy used only when the dynamic form fails to load."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Fallback heading",
      "default": "Apply for wholesale access"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Fallback intro copy",
      "default": "Tell us about your business. We review every application within 2 business days."
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Fallback submit button label",
      "default": "Submit application"
    },
    {
      "type": "text",
      "id": "success_heading",
      "label": "Fallback success heading",
      "default": "Application received"
    },
    {
      "type": "textarea",
      "id": "success_body",
      "label": "Fallback success body",
      "default": "Thanks — we'll review your application and email you within 2 business days."
    },
    {
      "type": "textarea",
      "id": "already_wholesale_text",
      "label": "Already-wholesale notice",
      "default": "You already have wholesale access. Head to the wholesale catalog to start ordering."
    }
  ]
}
{% endschema %}
