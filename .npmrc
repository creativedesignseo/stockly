engine-strict=true
@shopify:registry=https://registry.npmjs.org
# Required for Vercel's install step: @vercel/remix@2.16.7 has a strict peer
# dep on @remix-run/dev@2.16.7 but we use 2.17.4 (latest minor). The runtime
# behaviour is compatible — only the version pin is stricter than needed.
legacy-peer-deps=true
